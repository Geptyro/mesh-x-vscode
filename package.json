{
  "name": "falcra-vscode",
  "displayName": "Falcra Asset Editor",
  "description": "Visual editor + 3D preview for falcra-assets config.json files",
  "version": "0.0.1",
  "publisher": "starbor",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "onCustomEditor:falcra.configEditor"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "falcra.configEditor",
        "displayName": "Falcra Asset Editor",
        "selector": [
          {
            "filenamePattern": "**/*.falcra.json"
          },
          {
            "filenamePattern": "**/*.falcra-preview.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build:webview": "node scripts/build-webview.mjs",
    "dev": "node scripts/build-webview.mjs --watch",
    "link": "node scripts/link.js",
    "unlink": "node scripts/unlink.js"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/vscode": "^1.85.0",
"svelte": "^5.50.2",
    "three": "^0.182.0",
    "vite": "^7.3.1"
  }
}
