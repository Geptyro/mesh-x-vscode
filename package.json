{
  "name": "mesh-x-vscode",
  "displayName": "mesh-x Asset Editor",
  "description": "Visual editor + 3D preview for mesh-x procedural asset configs",
  "version": "0.0.1",
  "publisher": "geptyro",
  "repository": {
    "type": "git",
    "url": "https://github.com/Geptyro/mesh-x-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "onCustomEditor:meshx.configEditor"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "meshx.configEditor",
        "displayName": "mesh-x Asset Editor",
        "selector": [
          {
            "filenamePattern": "**/*.meshx.json"
          },
          {
            "filenamePattern": "**/*.meshx-preview.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build:webview": "node scripts/build-webview.mjs",
    "dev": "node scripts/build-webview.mjs --watch",
    "link": "node scripts/link.js",
    "unlink": "node scripts/unlink.js"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/vscode": "^1.85.0",
    "svelte": "^5.50.2",
    "three": "^0.182.0",
    "vite": "^7.3.1"
  },
  "license": "MIT"
}
